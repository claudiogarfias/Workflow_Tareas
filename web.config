<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <handlers>
            <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" requireAccess="Script" />
        </handlers>
        <!-- 
            processPath: Ruta al ejecutable de Python en el servidor Windows.
            Por defecto se usa "python.exe" si está configurado en el PATH del sistema,
            o se puede especificar la ruta absoluta (ej. C:\Program Files\Python310\python.exe).
            
            arguments: Archivo a ejecutar (run_waitress.py).
            
            stdoutLogEnabled: Habilitado para depuración de logs en tiempo real.
            stdoutLogFile: Archivo donde se guardará la consola de Python (muy útil si hay errores 500/502).
        -->
        <httpPlatform stdoutLogEnabled="true" stdoutLogFile=".\python.log" startupTimeLimit="60" 
                      processPath="python.exe" 
                      arguments="run_waitress.py">
            <environmentVariables>
                <environmentVariable name="PYTHONPATH" value="." />
                <environmentVariable name="FLASK_ENV" value="production" />
            </environmentVariables>
        </httpPlatform>
    </system.webServer>
</configuration>
